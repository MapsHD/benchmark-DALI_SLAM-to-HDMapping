<launch>
	<!-- Benchmark launch for DA-LIO: same as run_dalio.launch but the config
	     file is selectable via the config_file arg (the upstream launch hardcodes
	     helmet_mid.yaml) and rviz defaults on for the live view. -->

	<arg name="rviz" default="true" />
	<arg name="config_file" default="helmet_mid.yaml" />

	<rosparam command="load" file="$(find da_lio)/config/$(arg config_file)" />

	<param name="feature_extract_enable" type="bool" value="0"/>
	<param name="point_filter_num" type="int" value="2"/>
	<param name="max_iteration" type="int" value="3" />
	<param name="filter_size_surf" type="double" value="0.2" />
	<param name="filter_size_map" type="double" value="0.2" />
	<param name="cube_side_length" type="double" value="1000" />
	<param name="runtime_pos_log_enable" type="bool" value="0" />
	<node pkg="da_lio" type="da_lio" name="da_lio" output="screen" />

	<group if="$(arg rviz)">
		<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find da_lio)/rviz_cfg/loam_livox.rviz" />
	</group>

</launch>
